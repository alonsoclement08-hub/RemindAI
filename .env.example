# URL base pour le serveur API de RemindAI
EXPO_PUBLIC_API_URL=http://localhost:4000/api

# Client IDs Google créés sur Google Cloud Console
# Facultatif si vous n'utilisez qu'une plateforme, configurez celui correspondant :
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=votre-google-client-id-web.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=votre-google-client-id-ios.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=votre-google-client-id-android.apps.googleusercontent.com

# Ancien format fallback (identique à WEB)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=votre-google-client-id-web.apps.googleusercontent.com
