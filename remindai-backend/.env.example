NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgresql://remindai:password@localhost:5432/remindai_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT — générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-char-random-string-here
JWT_REFRESH_SECRET=your-other-64-char-random-string-here

# Google AI (Gemma) — obtenir sur https://aistudio.google.com/app/apikey
GEMMA_API_KEY=your-google-ai-api-key-here
GEMMA_MODEL=gemma-3-27b-it
