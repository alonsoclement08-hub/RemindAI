generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  name          String?
  tier          Tier     @default(free)
  createdAt     DateTime @default(now()) @map("created_at")

  reminders            Reminder[]
  budgets              Budget[]
  syncLogs             SyncLog[]
  deviceTokens         DeviceToken[]
  notificationHistory  NotificationHistory[]

  @@map("users")
}

model Reminder {
  id              String      @id @default(uuid())
  userId          String      @map("user_id")
  title           String
  description     String?
  scheduledAt     DateTime?   @map("scheduled_at")
  completedAt     DateTime?   @map("completed_at")
  deletedAt       DateTime?   @map("deleted_at")
  archivedAt      DateTime?   @map("archived_at")
  priority        Int         @default(2)
  category        Category    @default(personal)
  frequency       Frequency   @default(once)
  frequencyDays   Json?       @map("frequency_days")
  nextOccurrence  DateTime?   @map("next_occurrence")
  contextAi       String?     @map("context_ai")
  notifyBefore    Int?        @map("notify_before")
  useGeolocation  Boolean     @default(false) @map("use_geolocation")
  locationName    String?     @map("location_name")
  locationLat     Float?      @map("location_lat")
  locationLng     Float?      @map("location_lng")
  locationRadius  Int         @default(500) @map("location_radius")
  geoNotified     Boolean     @default(false) @map("geo_notified")
  syncStatus      SyncStatus  @default(pending) @map("sync_status")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user                User                  @relation(fields: [userId], references: [id])
  syncLogs            SyncLog[]
  notificationHistory NotificationHistory[]

  @@index([scheduledAt])
  @@index([syncStatus])
  @@index([useGeolocation, geoNotified])
  @@map("reminders")
}

model Budget {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  category       String   @default("errand")
  budgetLimit    Float    @map("budget_limit")
  period         String   @default("monthly") // weekly, monthly, yearly
  alertThreshold Float    @default(0.8) @map("alert_threshold")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, category, period])
  @@map("budgets")
}

model SyncLog {
  id              String     @id @default(uuid())
  userId          String     @map("user_id")
  reminderId      String     @map("reminder_id")
  action          SyncAction
  syncStatus      SyncStatus @default(pending) @map("sync_status")
  clientTimestamp DateTime   @map("client_timestamp")
  serverTimestamp DateTime   @default(now()) @map("server_timestamp")

  user     User     @relation(fields: [userId], references: [id])
  reminder Reminder @relation(fields: [reminderId], references: [id])

  @@map("sync_logs")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  platform  Platform
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("device_tokens")
}

model NotificationHistory {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  reminderId String    @map("reminder_id")
  sentAt     DateTime  @default(now()) @map("sent_at")
  openedAt   DateTime? @map("opened_at")
  platform   Platform

  user     User     @relation(fields: [userId], references: [id])
  reminder Reminder @relation(fields: [reminderId], references: [id])

  @@map("notification_history")
}

enum Tier {
  free
  pro
}

enum Category {
  work
  personal
  health
  errand
  habit
  call
}

enum Frequency {
  once
  daily
  weekly
  monthly
  custom
}

enum SyncStatus {
  pending
  synced
  conflict
}

enum SyncAction {
  create
  update
  delete
}

enum Platform {
  ios
  android
}
